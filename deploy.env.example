# Copy to deploy.env and fill in. deploy.env is gitignored (machine-specific).
# Used by scripts/deploy.sh and scripts/sync-data.sh.

# SSH connection to the Debian VM (must have key-based SSH set up).
VM_USER=youruser
VM_HOST=192.168.1.50

# Where compose.yaml + .env live on the VM (created if missing).
REMOTE_DIR=/home/youruser/map-tracker

# Host directory bind-mounted into the container at /data (holds the maps).
# /var/lib/... needs root to create/chown, so USE_SUDO=1 below. To avoid sudo,
# point this at a path your SSH user owns, e.g. /home/youruser/map-tracker-data.
VM_DATA_DIR=/var/lib/map-tracker

# Run remote dir/permission setup with sudo (needed for /var/lib paths).
# Set to empty to skip (when VM_DATA_DIR is user-owned).
USE_SUDO=1

# Image name/tag and target platform (Debian VMs are almost always amd64; your
# Mac is arm64, so the image is cross-built for this platform).
IMAGE=map-tracker:latest
PLATFORM=linux/amd64
